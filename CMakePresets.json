{
  "version": 6,
  "configurePresets": [
    {
      "name": "msys2-gcc",
      "displayName": "MSYS2 GCC Configuration",
      "description": "MSYS2环境下的GCC配置，用于生成正确的compile_commands.json",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_C_STANDARD": "17",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_FLAGS": "",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "msys2-gcc"
    }
  ]
}